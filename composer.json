{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/standard-user",
    "description": "Sovereign user blueprint for Webkernel. Provides the base Eloquent model, Filament integration, and runtime auth configuration injection.",
    "version": "0.1.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "webkernel-engine",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/standard-user/issues"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "webkernel/standard-lifecycle": ">=0.1.0",
        "filament/filament": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Webkernel\\StdUser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkernel\\StdUser\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkernel\\StdUser\\Providers\\StdUserServiceProvider"
            ]
        },
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/standard-user.git",
            "prefix": "standard-user",
            "config_scope": "auth"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
